# ---- Railway injects DATABASE_URL automatically when you add a Postgres plugin ----
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ---- UChat ----
UCHAT_API_TOKEN=put_NEW_uchat_token_here

# ---- Chatwoot ----
CHATWOOT_BASE_URL=https://chat.engosoft.com
CHATWOOT_API_TOKEN=put_NEW_chatwoot_token_here
ACCOUNT_ID=2
INBOX_ID=25

# ---- Optional assignment mapping ----
# If Salesperson names in Excel don't exactly match Chatwoot agent names/emails,
# map the Excel name to the Chatwoot agent ID. JSON or Name=ID pairs are accepted.
# CHATWOOT_AGENT_MAP={"Ahmed  El-Shiekh":12,"Nader Aziz":13}
CHATWOOT_AGENT_MAP=

# ---- UChat chat history fetch ----
# UChat excludes bot messages by default unless include_bot=1.
UCHAT_INCLUDE_BOT=1
UCHAT_INCLUDE_NOTE=1
UCHAT_INCLUDE_SYSTEM=0
UCHAT_MSG_LIMIT=100

# ---- Optional date filter (leave empty = migrate everyone) ----
# Only contacts with last_interaction >= this date get queued.
MIGRATE_SINCE=

# ---- Pacing (safe defaults; tune without code changes) ----
RATE_MSG_DELAY=0.5
RATE_USER_DELAY=2
IDLE_POLL_DELAY=15
DOWN_BACKOFF=30
BREAK_EVERY=500
BREAK_SECONDS=60
