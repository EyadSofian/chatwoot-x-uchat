# ---- Railway injects DATABASE_URL automatically when you add a Postgres plugin ----
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ---- UChat ----
UCHAT_API_TOKEN=put_NEW_uchat_token_here

# ---- Chatwoot ----
CHATWOOT_BASE_URL=https://chat.engosoft.com
CHATWOOT_API_TOKEN=put_NEW_chatwoot_token_here
ACCOUNT_ID=2
INBOX_ID=25

# ---- Optional date filter (leave empty = migrate everyone) ----
# Only contacts with last_interaction >= this date get queued.
MIGRATE_SINCE=

# ---- Pacing (safe defaults; tune without code changes) ----
RATE_MSG_DELAY=0.5
RATE_USER_DELAY=2
IDLE_POLL_DELAY=15
DOWN_BACKOFF=30
BREAK_EVERY=500
BREAK_SECONDS=60
